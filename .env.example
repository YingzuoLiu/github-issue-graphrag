# Copy this file to .env and fill in local values.
# Never commit .env.

# LLM provider options: openai-compatible, mock
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Embedding provider options: sentence-transformers, mock
EMBEDDING_PROVIDER=mock
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# Optional GitHub token for higher rate limits when fetching issues.
GITHUB_TOKEN=

# Local paths
RAW_DATA_DIR=data/raw
PROCESSED_DATA_DIR=data/processed
